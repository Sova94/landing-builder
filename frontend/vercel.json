{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "devCommand": "npm run dev",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/hub",
      "destination": "/hub"
    },
    {
      "source": "/editor/:path*",
      "destination": "/index.html"
    },
    {
      "source": "/preview/:path*",
      "destination": "/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/$1"
    }
  ],
  "installCommand": "npm install --legacy-peer-deps && npx playwright install --with-deps chromium"
}
