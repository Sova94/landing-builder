{
  "buildCommand": "npx vite build --mode production",
  "outputDirectory": "dist",
  "devCommand": "npm run dev",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/hub",
      "destination": "/hub"
    },
    {
      "source": "/editor/:path*",
      "destination": "/index.html"
    },
    {
      "source": "/preview/:path*",
      "destination": "/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/$1"
    }
  ],
  "ignoreCommand": "git diff --quiet HEAD^ HEAD -- ."
}
