{
  "buildCommand": "vite build --config vite.config.production.ts",
  "outputDirectory": "dist",
  "devCommand": "npm run dev",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/hub",
      "destination": "/hub"
    },
    {
      "source": "/editor/:path*",
      "destination": "/index.html"
    },
    {
      "source": "/preview/:path*",
      "destination": "/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/$1"
    }
  ]
}
